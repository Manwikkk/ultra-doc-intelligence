# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# At least one key is required. Providers are tried in order: Groq → OpenAI → Gemini → Ollama
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Ollama (local, no API key needed) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Model Names ───────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-3.5-turbo
GEMINI_MODEL=gemini-1.5-flash

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DIR=./storage

# ── RAG Parameters ────────────────────────────────────────────────────────────
TOP_K=5
SIMILARITY_THRESHOLD=0.35
CONFIDENCE_THRESHOLD=0.30
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ── LLM Timeout (seconds) ─────────────────────────────────────────────────────
LLM_TIMEOUT=60
